APP_ENV=local
APP_PORT=8080

DATABASE_URL=postgres://smartcampus:smartcampus_password@postgres:5432/smartcampus?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change_me
JWT_ACCESS_TTL=24h

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

AI_PROVIDER=openai_compatible
# Вставь сюда API-ключ OpenAI (ChatGPT Plus → platform.openai.com → API keys, sk-...)
AI_API_KEY=
# Базовый URL OpenAI. Оставь пустым — будет использован https://api.openai.com/v1
AI_BASE_URL=
# Модель OpenAI. Рекомендуется gpt-4o-mini (быстрая и дешёвая) или gpt-4o.
AI_MODEL=gpt-4o-mini

ALLOW_PUBLIC_ADMIN_REGISTER=false

RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_MINUTE=3
RATE_LIMIT_API_PER_MINUTE=100
RATE_LIMIT_AI_PER_MINUTE=20
